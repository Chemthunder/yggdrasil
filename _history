h1":38,"diffs":[[1,"    set content(input: any) {\n"]]},{"start1":388,"length1":0,"diffs":[[1,"}\n\nclass ProtectedKey {\n    _content: any;\n    _project: Initializer;\n    _isLocked: boolean;\n\n    constructor(content: any, project: Initializer) {\n        this._content = content;\n        this._project = project;\n    }\n\n    get content(): any {\n        return this._content;\n    }\n\n    set content(input: any) {\n        this.content = input;\n    }\n\n    get project(): Initializer {\n        return this._project;\n    }\n\n    set project(input: Initializer) {\n        this.project = input;\n    }\n\n    private get isLocked(): boolean {\n        return this.isLocked;\n    }\n\n    private set isLocked(bl: boolean) {\n        this.isLocked = bl;\n    }\n\n    lock(bl?: boolean) {\n        try {\n            if (bl != null) {\n                this.isLocked = bl;\n            } else {\n                this.isLocked = !this.lockedState;\n            }\n        } catch {\n            Yggdrasil.stop(\"Failed to lock ProtectedKey.class!\");\n        }\n    }\n\n    unpack(): any {\n        try {\n            if (!this.lockedState) { // if is not locked\n                return this.content;\n            } else {\n                Yggdrasil.log(\"Could not access ProtectedKey contents due to edited key being locked.\", InfoType.ERR);\n            }\n        } catch {\n            Yggdrasil.stop(\"Failed to unpack ProtectedKey.class!\");\n        }\n    }\n"]]}]},{"type":"edited","filename":"Keys.ts","patch":[{"start1":842,"length1":75,"diffs":[[1,"class CompatKey extends Key {\n    _compat: any;\n    _init: Initializer;\n"]]},{"start1":915,"length1":99,"diffs":[[1,"    constructor(compat: any, init: Initializer) {\n        super(compat);\n        this._init = init;\n"]]},{"start1":1021,"length1":2,"diffs":[[1,""]]},{"start1":1022,"length1":46,"diffs":[[1,"    get init(): Initializer {\n        return this._init;\n    }\n"]]},{"start1":1086,"length1":75,"diffs":[[1